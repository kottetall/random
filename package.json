{
  "name": "@kottetall/random",
  "version": "0.0.9",
  "description": "",
  "release": {
    "branches": [
      "+([0-9])?(.{+([0-9]),x}).x",
      "master",
      "main",
      "next",
      "next-major",
      {
        "name": "beta",
        "prerelease": true
      },
      {
        "name": "alpha",
        "prerelease": true
      }
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  },
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "scripts": {
    "test": "vitest",
    "clean": "del-cli ./lib",
    "build": "npm run clean && tsc -p ./tsconfig.json",
    "prepack": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kottetall/random.git"
  },
  "keywords": [
    "random",
    "random-generator",
    "random-utils",
    "random-string",
    "random-word",
    "random-sentence",
    "random-paragraph",
    "random-color",
    "array-sampling",
    "probability",
    "shuffle-array",
    "probability",
    "typescript",
    "javascript",
    "utility-library"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/kottetall/random/issues"
  },
  "homepage": "https://github.com/kottetall/random#readme",
  "files": [
    "lib/**/*"
  ],
  "devDependencies": {
    "del-cli": "^7.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
